# Required API key for all API routes except /health.
AGENTGUARD_API_KEY=change-this-local-dev-key

# Backend audit database path. Defaults to ~/.agentguard/agentguard_audit.db when unset.
AGENTGUARD_DB=./data/agentguard_audit.db

# Comma-separated frontend origins allowed by the FastAPI CORS middleware.
AGENTGUARD_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Frontend build/runtime API URL for local Vite development.
VITE_AGENTGUARD_API_URL=http://127.0.0.1:8000

# Local Vite development only. Docker uses the Nginx /api proxy instead.
VITE_AGENTGUARD_API_KEY=change-this-local-dev-key
